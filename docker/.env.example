# ==========================================
# FRONTEND CONFIGURATION (NEXT.JS)
# ==========================================
# Next.js requires the NEXT_PUBLIC_ prefix to expose variables to the browser
NEXT_PUBLIC_API_URL=http://localhost:8080/api

# ==========================================
# BACKEND CONFIGURATION (.NET 9)
# ==========================================
ASPNETCORE_ENVIRONMENT=Development
ConnectionStrings__DefaultConnection=Host=postgres;Database=craftvision;Username=postgres;Password=postgres

# ==========================================
# DATABASE (POSTGRES)
# ==========================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=craftvision
